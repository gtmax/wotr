#!/usr/bin/env bash
set -e

COMMAND="${1}"
REQUIRED_RUBY="3.2.0"
BREW_RUBY="/opt/homebrew/opt/ruby/bin/ruby"
BREW_GEM="/opt/homebrew/opt/ruby/bin/gem"

# Returns the path to a ruby binary that meets the version requirement, or empty string
find_ruby() {
  for candidate in "$(which ruby 2>/dev/null)" "$BREW_RUBY"; do
    [ -x "$candidate" ] || continue
    version=$("$candidate" -e 'print RUBY_VERSION' 2>/dev/null)
    if ruby_meets_requirement "$version" "$REQUIRED_RUBY"; then
      echo "$candidate"
      return
    fi
  done
}

# Compare semantic versions: returns 0 if $1 >= $2
ruby_meets_requirement() {
  printf '%s\n%s\n' "$2" "$1" | sort -V -C
}

ensure_ruby() {
  RUBY=$(find_ruby)
  if [ -n "$RUBY" ]; then
    GEM=$(dirname "$RUBY")/gem
    return 0
  fi

  echo "Ruby $REQUIRED_RUBY+ is required but not found."
  if ! command -v brew >/dev/null 2>&1; then
    echo "Install Ruby manually: https://www.ruby-lang.org/en/documentation/installation/"
    exit 1
  fi

  printf "Install Ruby via Homebrew? [y/N] "
  read -r REPLY
  if [[ "$REPLY" =~ ^[Yy]$ ]]; then
    brew install ruby
    RUBY="$BREW_RUBY"
    GEM="$BREW_GEM"
  else
    echo "Aborted."
    exit 1
  fi
}

case "$COMMAND" in
  install)
    ensure_ruby
    echo "Using Ruby $("$RUBY" -e 'print RUBY_VERSION')"
    echo "Building gem..."
    "$RUBY" -S gem build wotr.gemspec
    # Remove stale gem bin wrappers that conflict with re-install
    GEM_BIN_PRE=$("$GEM" environment | awk '/EXECUTABLE DIRECTORY/ {print $NF}')
    for wrapper in wotr-output wotr-default-setup wotr-rename-tab; do
      rm -f "$GEM_BIN_PRE/$wrapper" 2>/dev/null
    done
    echo "Installing gem..."
    "$GEM" install --force wotr-*.gem
    rm -f wotr-*.gem
    # Symlink wotr (gem executable) into /opt/homebrew/bin
    GEM_BIN=$("$GEM" environment | awk '/EXECUTABLE DIRECTORY/ {print $NF}')
    if [ -d "/opt/homebrew/bin" ] && [ -f "$GEM_BIN/wotr" ]; then
      ln -sf "$GEM_BIN/wotr" "/opt/homebrew/bin/wotr"
      echo "Symlinked wotr → /opt/homebrew/bin/wotr"
    fi
    # Symlink Ruby-based executables and copy shell scripts into /opt/homebrew/bin
    GEM_DIR=$("$GEM" environment gemdir)
    GEM_BIN_INSTALLED=$("$GEM" environment | awk '/EXECUTABLE DIRECTORY/ {print $NF}')
    for script in wotr-default-setup wotr-output wotr-rename-tab; do
      SRC=$(ls "$GEM_DIR/gems/wotr-"*/exe/$script 2>/dev/null | tail -1)
      if [ -n "$SRC" ] && [ -d "/opt/homebrew/bin" ]; then
        cp "$SRC" "/opt/homebrew/bin/$script"
        chmod +x "/opt/homebrew/bin/$script"
        echo "Installed $script → /opt/homebrew/bin/$script"
      fi
    done
    # Create ~/.wotr/setup template if it doesn't exist yet
    if [ ! -f "$HOME/.wotr/setup" ]; then
      mkdir -p "$HOME/.wotr"
      cat > "$HOME/.wotr/setup" <<'SETUP'
#!/bin/bash
# ~/.wotr/setup — runs when creating a new worktree in any repo.
#
# wotr-defaults symlinks .env, node_modules, and .claude from the repo root.
# Remove it to opt out. Add your own steps below.
wotr-defaults
SETUP
      chmod +x "$HOME/.wotr/setup"
      echo "Created ~/.wotr/setup"
    else
      echo "~/.wotr/setup already exists, skipping."
    fi
    echo "Done. Run 'wotr' to launch."
    ;;
  *)
    echo "Usage: bin/dev <command>"
    echo ""
    echo "Commands:"
    echo "  install   Build and install wotr locally (installs Ruby via Homebrew if needed)"
    ;;
esac
