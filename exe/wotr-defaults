#!/usr/bin/env bash
# wotr-defaults — apply wotr's built-in default worktree setup.
#
# Call this from ~/.wotr/setup or .wotr/setup to opt into the defaults
# while still running your own custom steps:
#
#   #!/bin/bash
#   wotr-defaults        # apply defaults
#   pnpm install        # then your custom steps
#
# Requires WOTR_ROOT to be set (done automatically by wotr).

set -e

if [ -z "$WOTR_ROOT" ]; then
  echo "wotr-defaults: WOTR_ROOT is not set. Run this from within a wotr setup hook." >&2
  exit 1
fi

# Plain symlinks: safe to share across worktrees
for file in .env node_modules; do
  if [ -e "$WOTR_ROOT/$file" ] && [ ! -e "$file" ]; then
    ln -sf "$WOTR_ROOT/$file" "$file"
    echo "  Symlinked $file"
  fi
done

# .claude: create a real directory, symlink all contents from root,
# but copy settings.local.json so runtime permission approvals stay isolated.
if [ -d "$WOTR_ROOT/.claude" ] && [ ! -e ".claude" ]; then
  mkdir .claude
  for item in "$WOTR_ROOT/.claude/"* "$WOTR_ROOT/.claude/".?*; do
    [ -e "$item" ] || continue
    name=$(basename "$item")
    [ "$name" = "." ] || [ "$name" = ".." ] || [ "$name" = "settings.local.json" ] && continue
    ln -sf "$item" ".claude/$name"
  done
  echo "  Created .claude/ (symlinked contents)"

  if [ -f "$WOTR_ROOT/.claude/settings.local.json" ]; then
    cp "$WOTR_ROOT/.claude/settings.local.json" ".claude/settings.local.json"
    echo "  Copied .claude/settings.local.json (isolated)"
  fi
fi
